# ─────────────────────────────────────────────────────────────
#  VYAPAAR — Environment Configuration
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=your-very-secret-flask-key-change-this
FLASK_ENV=development
FLASK_DEBUG=True

# Render PostgreSQL — your metadataloop_db
DATABASE_URL=postgresql://username:password@hostname:5432/metadataloop_db

# App URL (used for Fyers OAuth callback)
# Local: http://localhost:5000
# Production: https://yourdomain.onrender.com
APP_BASE_URL=http://localhost:5000

# Fyers OAuth Redirect (must match what you set in myapi.fyers.in)
# Use Fyers' own sample page (works without HTTPS on localhost)
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html

# When deployed to Render/Railway with HTTPS, switch to:
# FYERS_REDIRECT_URI=https://yourdomain.onrender.com/fyers/callback

# Timezone (Indian Standard Time)
TIMEZONE=Asia/Kolkata
